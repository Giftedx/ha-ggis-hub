# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Hermes local tooling state; canonical project docs live outside this directory.
.hermes/

# JavaScript / TypeScript dependencies and build output
node_modules/
dist/
.wrangler/
coverage/
playwright-report/
test-results/

# Rust build output
target/

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Scratch — local smoke artifacts, screenshots, etc.
.tmp/

# Per-session worktrees created by Claude Code's EnterWorktree tool
.claude/worktrees/
# Review scratchpads created by game-review / purpose-audit slash commands
.claude/review-notes.md
.claude/purpose-audit.md
.review-notes.md
.purpose-audit.md

# Serena MCP plugin local state (project cache, memories, machine config).
.serena/

# Superpowers brainstorm scratch (transient local server state, pids, html shells).
.superpowers/

# Research image references (large, local-only; tracked separately if needed).
docs/research/refs/
docs/research/*.zip

# haggis-eval CLI build artifacts (reports already covered by target/ above)
tools/haggis-eval/haggis-eval
tools/haggis-eval/haggis-eval.exe
