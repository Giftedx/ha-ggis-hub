{
  "name": "ha-ggis-hub",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "description": "Playable Rust/WASM haggis games lobby for ha.ggis.xyz.",
  "engines": {
    "node": ">=22 <26",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build:wasm": "wasm-pack build crates/hub-wasm --target web --out-dir ../../src/generated/hub-wasm --release",
    "build": "pnpm run build:wasm && vite build",
    "build:verified": "pnpm run build && node scripts/verify-dist.mjs",
    "build:whs": "npm --prefix ../wild-haggis-survivors run build",
    "copy:whs": "node scripts/copy-whs-build.mjs",
    "build:all": "pnpm run build && pnpm run build:whs && pnpm run copy:whs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ scripts/ vite.config.ts --max-warnings=0",
    "fmt:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\"",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check && pnpm run test && pnpm run build:verified",
    "rasterize:og": "node scripts/rasterize-og.mjs",
    "rasterize:music": "node scripts/render-wario-share-audio.mjs",
    "visual:capture": "node scripts/run-visual-gate.mjs capture",
    "visual:verify": "node scripts/run-visual-gate.mjs verify",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "10.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
