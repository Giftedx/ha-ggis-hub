{
  "name": "ha-ggis-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "description": "Playable Rust/WASM haggis game hub for ha.ggis.xyz.",
  "engines": {
    "node": ">=22 <26",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build": "vite build",
    "build:verified": "vite build && node scripts/verify-dist.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build:verified",
    "rasterize:og": "node scripts/rasterize-og.mjs",
    "visual:capture": "node scripts/run-visual-gate.mjs capture",
    "visual:verify": "node scripts/run-visual-gate.mjs verify"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "typescript": "5.9.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
